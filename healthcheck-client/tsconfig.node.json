{
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noEmit": true,

    "strict": true
  },
  "include": ["vite.config.ts"]
}